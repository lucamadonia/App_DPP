# DPP Manager - Umgebungsvariablen
# Kopieren Sie diese Datei nach .env und ersetzen Sie die Platzhalter

# Supabase Configuration
# Finden Sie diese Werte in Ihrem Supabase Dashboard unter Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: API URL für zusätzliche Backend-Services
VITE_API_URL=/api

# OpenRouter API Key - stored as Supabase Secret (NOT in frontend!)
# Set via: supabase secrets set OPENROUTER_API_KEY=sk-or-v1-...
# The key is used by the openrouter-proxy Edge Function server-side.

# ── Mail Hub (Family-Joy) ────────────────────────────────────────────
# Client-side flags steer ROUTING only — no secrets in the bundle.
# VITE_MAIL_HUB_VIA_FAMILY_JOY=true            # route Fambliss tenant mails via Family-Joy
# VITE_MAIL_HUB_TENANT_IDS=<uuid,uuid,...>     # tenant allowlist (default: MYFAMBLISS GmbH)
#
# The HMAC secret + receiver URL are SERVER-SIDE Supabase Secrets used by
# the mail-hub-forward Edge Function (never put them in VITE_ vars!):
#   supabase secrets set MAIL_HUB_SECRET=<MAIL_EVENT_RECEIVER_SECRET from Family-Joy>
#   supabase secrets set MAIL_HUB_URL=https://bkaaepzqejzdczivquoh.supabase.co/functions/v1/mail-event-receiver
#
# DEPRECATED (do not use — secret would leak into the JS bundle):
#   VITE_MAIL_HUB_URL, VITE_MAIL_HUB_SECRET
